{
    "name": "@viveksinghind/narrative-form-angular",
    "version": "1.0.9",
    "description": "Angular components for narrative-form — typewriter-style sign-up flow",
    "author": "Vivek Singh <vivekSinghInd>",
    "license": "MIT",
    "sideEffects": false,
    "publishConfig": {
        "directory": "dist"
    },
    "main": "fesm2022/viveksinghind-narrative-form-angular.mjs",
    "module": "fesm2022/viveksinghind-narrative-form-angular.mjs",
    "typings": "index.d.ts",
    "exports": {
        "./package.json": {
            "default": "./package.json"
        },
        ".": {
            "types": "./index.d.ts",
            "esm2022": "./esm2022/viveksinghind-narrative-form-angular.mjs",
            "esm": "./esm2022/viveksinghind-narrative-form-angular.mjs",
            "default": "./fesm2022/viveksinghind-narrative-form-angular.mjs"
        }
    },
    "scripts": {
        "build": "ng-packagr -p ng-package.json",
        "clean": "rimraf dist",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "test": "jest"
    },
    "dependencies": {
        "@viveksinghind/narrative-form-core": "workspace:*",
        "tslib": "^2.6.2"
    },
    "peerDependencies": {
        "@angular/common": ">=15.0.0",
        "@angular/core": ">=15.0.0"
    },
    "devDependencies": {
        "@angular/compiler": "^18.0.0",
        "@angular/compiler-cli": "^18.0.0",
        "@angular/core": "^18.0.0",
        "@angular/common": "^18.0.0",
        "ng-packagr": "^18.0.0",
        "rimraf": "^5.0.5",
        "typescript": "5.4.5",
        "@storybook/angular": "^8.1.11",
        "@storybook/addon-essentials": "^8.1.11",
        "@storybook/addon-links": "^8.1.11",
        "@storybook/addon-interactions": "^8.1.11",
        "@storybook/blocks": "^8.1.11",
        "storybook": "^8.1.11",
        "jest": "^29.7.0",
        "jest-preset-angular": "^14.1.1",
        "@types/jest": "^29.5.12",
        "rxjs": "^7.8.0"
    },
    "keywords": [
        "angular",
        "narrative-form",
        "typewriter",
        "form",
        "onboarding",
        "signup",
        "typescript"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/vivekSinghInd/narrative-form.git",
        "directory": "packages/angular"
    }
}
