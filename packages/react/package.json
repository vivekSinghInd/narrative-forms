{
    "name": "@viveksinghind/narrative-form-react",
    "version": "1.0.9",
    "description": "React components for narrative-form — typewriter-style sign-up flow",
    "author": "Vivek Singh <vivekSinghInd>",
    "license": "MIT",
    "main": "dist/index.cjs",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "sideEffects": false,
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./style.css": "./dist/index.css",
        "./dist/index.css": "./dist/index.css"
    },
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit",
        "test": "jest",
        "clean": "rimraf dist",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build"
    },
    "dependencies": {
        "@viveksinghind/narrative-form-core": "workspace:*"
    },
    "peerDependencies": {
        "react": ">=17.0.0",
        "react-dom": ">=17.0.0"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.4.2",
        "@testing-library/react": "^15.0.6",
        "@testing-library/user-event": "^14.5.2",
        "@types/react": "^18.3.1",
        "@types/react-dom": "^18.3.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "rimraf": "^5.0.5",
        "storybook": "^8.1.11",
        "@storybook/react": "^8.1.11",
        "@storybook/react-vite": "^8.1.11",
        "@storybook/addon-essentials": "^8.1.11",
        "@storybook/addon-links": "^8.1.11",
        "@storybook/addon-interactions": "^8.1.11",
        "@storybook/blocks": "^8.1.11",
        "vite": "^5.3.1",
        "tsup": "^8.0.2",
        "typescript": "^5.4.5"
    },
    "keywords": [
        "react",
        "narrative-form",
        "typewriter",
        "form",
        "onboarding",
        "signup",
        "typescript"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/vivekSinghInd/narrative-form.git",
        "directory": "packages/react"
    },
    "homepage": "https://github.com/vivekSinghInd/narrative-form#readme",
    "bugs": {
        "url": "https://github.com/vivekSinghInd/narrative-form/issues"
    }
}
